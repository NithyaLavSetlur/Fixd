<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Fixd" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorSecondaryVariant">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="gradientMidColor">@color/brand_gradient_mid</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="colorOnSurface">@color/brand_text</item>
        <item name="android:windowBackground">@color/brand_surface</item>
        <item name="android:statusBarColor">@color/brand_card</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/brand_card</item>
        <item name="colorControlHighlight">@color/transparent</item>
        <item name="android:colorControlHighlight">@color/transparent</item>
        <item name="materialButtonStyle">@style/Widget.Fixd.Button</item>
        <item name="editTextStyle">@style/Widget.Fixd.TextInputEditText</item>
        <item name="textInputStyle">@style/Widget.Fixd.TextInputLayout</item>
    </style>

    <style name="Theme.Fixd.Splash" parent="Theme.Fixd">
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <style name="Theme.Fixd.Alarm" parent="Theme.Fixd">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/brand_primary_dark</item>
    </style>

    <style name="ThemeOverlay.Fixd.Palette.Ocean" parent="">
        <item name="colorPrimary">#0F5D7A</item>
        <item name="colorPrimaryVariant">#083C54</item>
        <item name="colorSecondary">#2F8FCE</item>
        <item name="colorSecondaryVariant">#2F8FCE</item>
        <item name="gradientMidColor">#168AA7</item>
    </style>

    <style name="ThemeOverlay.Fixd.Palette.Mint" parent="">
        <item name="colorPrimary">#157765</item>
        <item name="colorPrimaryVariant">#0D5448</item>
        <item name="colorSecondary">#45CFA8</item>
        <item name="colorSecondaryVariant">#45CFA8</item>
        <item name="gradientMidColor">#27A88C</item>
    </style>

    <style name="ThemeOverlay.Fixd.Palette.Sunset" parent="">
        <item name="colorPrimary">#A44F3B</item>
        <item name="colorPrimaryVariant">#6F3327</item>
        <item name="colorSecondary">#E0895E</item>
        <item name="colorSecondaryVariant">#E0895E</item>
        <item name="gradientMidColor">#C8664D</item>
    </style>

    <style name="ThemeOverlay.Fixd.Palette.Orchid" parent="">
        <item name="colorPrimary">#5D49B5</item>
        <item name="colorPrimaryVariant">#3E327D</item>
        <item name="colorSecondary">#A977E5</item>
        <item name="colorSecondaryVariant">#A977E5</item>
        <item name="gradientMidColor">#7B62CC</item>
    </style>

    <style name="Widget.Fixd.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/transparent</item>
    </style>

    <style name="ShapeAppearance.Fixd.Tile" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.Fixd.Tile.Large" parent="ShapeAppearance.Fixd.Tile">
        <item name="cornerSize">28dp</item>
    </style>

    <style name="Widget.Fixd.TileCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Fixd.Tile</item>
    </style>

    <style name="Widget.Fixd.TileCard.Large" parent="Widget.Fixd.TileCard">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">6dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Fixd.Tile.Large</item>
    </style>

    <style name="Widget.Fixd.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/brand_card</item>
        <item name="boxStrokeColor">@color/brand_accent</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextColor">@color/brand_text_muted</item>
        <item name="android:textColorHint">@color/brand_text_muted</item>
    </style>

    <style name="Widget.Fixd.TextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">@color/brand_text</item>
        <item name="android:textColorHint">@color/brand_text_muted</item>
        <item name="android:textCursorDrawable">@null</item>
    </style>
</resources>
