    <string name="social_title">Social controls</string>
    <string name="social_body">Choose how Fixd should limit distracting surfaces inside supported social apps. This screen saves your preferences now, and cross-app enforcement will be expanded as the screen-control layer is added.</string>
    <string name="social_master_title">Allow Fixd to control supported apps</string>
    <string name="social_master_body">Turn this on when you want Fixd to apply your saved restrictions in supported apps like Instagram and YouTube.</string>
    <string name="social_status_ready">Controls enabled</string>
    <string name="social_status_paused">Controls paused</string>
    <string name="social_setup_note">This tab stores your restriction preferences to your account and now includes a first enforcement layer through Accessibility and overlay controls. Because Instagram and YouTube are third-party apps, blocking remains best-effort and may need updates as their UI changes.</string>
    <string name="social_permissions_title">Permissions and enforcement</string>
    <string name="social_permissions_body">To work on top of Instagram or YouTube, Fixd needs overlay permission for the floating controls and Accessibility access for device-level enforcement.</string>
    <string name="social_overlay_permission_granted">Overlay permission is enabled.</string>
    <string name="social_overlay_permission_missing">Overlay permission is still required for the floating bubble and on-screen blocker.</string>
    <string name="social_overlay_permission_button">Open overlay permission</string>
    <string name="social_accessibility_permission_button">Open accessibility settings</string>
    <string name="social_bubble_title">Floating Fixd icon</string>
    <string name="social_bubble_body">Use a separate floating Fixd icon on top of other apps so you can open and edit your Social settings without opening the main app.</string>
    <string name="social_bubble_toggle_title">Show floating Fixd icon</string>
    <string name="social_bubble_toggle_body">Keeps the Fixd app icon on the side of the screen so you can tap it to open the quick settings popup.</string>
    <string name="social_bubble_open_button">Open popup now</string>
    <string name="social_bubble_note">The floating icon uses the Fixd app icon and opens the same saved Instagram and YouTube Social controls.</string>
    <string name="social_bubble_steps">Grant overlay permission, turn on the floating icon here, then tap the icon from any screen to edit settings. Accessibility is still needed for device-level enforcement inside other apps.</string>
    <string name="social_shortcut_title">Android accessibility shortcut</string>
    <string name="social_shortcut_body">Use Android’s built-in accessibility button to open the same quick Social controls popup on top of other apps.</string>
    <string name="social_shortcut_note">There is no separate Fixd floating icon anymore. The quick settings popup now opens from the system accessibility shortcut.</string>
    <string name="social_shortcut_steps">Enable Fixd Social Control in Accessibility settings, then add the Android accessibility button or shortcut and use it whenever you want to open the popup.</string>
    <string name="social_instagram_title">Instagram</string>
    <string name="social_instagram_body">Instagram feed browsing stays allowed. Reels opened from the feed or the Reels tab are redirected to Messages, and reels opened from chats are closed back to the same chat thread.</string>
    <string name="social_instagram_reels_title">Disable Reels</string>
    <string name="social_instagram_reels_body">When enabled, Fixd blocks the Reels tab, reels opened from the feed, and reels opened from chats.</string>
    <string name="social_instagram_discover_title">Disable Feed tab</string>
    <string name="social_instagram_discover_body">When enabled, Fixd blocks Instagram’s main Feed tab and redirects it back to Messages.</string>
    <string name="social_instagram_messages_title">Messages redirect</string>
    <string name="social_instagram_messages_body">Feed browsing stays allowed. Reels opened from the feed or Reels tab are sent to Messages. Reels opened from chats are closed back to the same chat thread.</string>
    <string name="social_youtube_title">YouTube</string>
    <string name="social_youtube_body">YouTube can block the Shorts tab and Shorts opened from inside the app, while leaving normal Home feed browsing alone.</string>
    <string name="social_youtube_shorts_title">Disable Shorts</string>
    <string name="social_youtube_shorts_body">When enabled, Fixd redirects the Shorts tab and Shorts opened from the YouTube Home feed back to Home.</string>
    <string name="social_youtube_future_note">More YouTube controls will be added in a future update.</string>
    <string name="social_accessibility_service_label">Fixd Social Control</string>
    <string name="social_accessibility_service_summary">Best-effort blocking for restricted Instagram and YouTube surfaces.</string>
    <string name="social_accessibility_service_description">Lets Fixd detect supported social apps in the foreground and place a blocker on top of restricted surfaces such as Instagram Reels or YouTube Shorts.</string>
