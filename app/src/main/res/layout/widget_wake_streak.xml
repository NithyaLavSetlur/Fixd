<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_wake_streak"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widgetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/problem_wake_up"
                android:textAllCaps="true"
                android:textColor="@color/brand_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetStreakLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/brand_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/widgetCreateAlarmButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_button"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingTop="9dp"
            android:paddingEnd="14dp"
            android:paddingBottom="9dp"
            android:text="@string/widget_set_alarm"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widgetStreakPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/widgetStreakValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetStreakCaption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/widget_streak_caption"
                android:textColor="@color/brand_text_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widgetTodayPanel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/widgetTodayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_today_label"
                android:textColor="@color/brand_text_muted"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/brand_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetStatusDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/brand_text_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widgetRecentPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_widget_panel"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/widgetRecentLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_recent_label"
            android:textColor="@color/brand_text_muted"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetRecentPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="1"
            android:textColor="@color/brand_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetRecentSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:maxLines="1"
            android:textColor="@color/brand_text_muted"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
