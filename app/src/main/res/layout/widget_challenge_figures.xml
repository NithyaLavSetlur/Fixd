<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/challengeFiguresWidgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_wake_streak"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/challengeFiguresWidgetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/challenge_figures_widget_title"
        android:textAllCaps="true"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/challengeFiguresWidgetCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_widget_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/challengeFiguresWidgetEmojiOne"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/challengeFiguresWidgetCaptionOne"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/challengeFiguresWidgetEmojiTwo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/challengeFiguresWidgetCaptionTwo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/challengeFiguresWidgetEmojiThree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="34sp" />

            <TextView
                android:id="@+id/challengeFiguresWidgetCaptionThree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="2"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
