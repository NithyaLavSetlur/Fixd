<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_card"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="18dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_page_body"
            android:textColor="@color/brand_text_muted"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Fixd.TileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/brand_card"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Fixd.Tile">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme_title"
                    android:textColor="@color/brand_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_theme_body"
                    android:textColor="@color/brand_text_muted"
                    android:textSize="14sp" />

                <RadioGroup
                    android:id="@+id/themeModeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">

                    <RadioButton
                        android:id="@+id/themeSystem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_system"
                        android:textColor="@color/brand_text" />

                    <RadioButton
                        android:id="@+id/themeLight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_theme_light"
                        android:textColor="@color/brand_text" />

                    <RadioButton
                        android:id="@+id/themeDark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/settings_theme_dark"
                        android:textColor="@color/brand_text" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Fixd.TileCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/brand_card"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Fixd.Tile">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_background_title"
                    android:textColor="@color/brand_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/settings_background_body"
                    android:textColor="@color/brand_text_muted"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/brand_card"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Fixd.Tile">

                    <ImageView
                        android:id="@+id/backgroundPreviewImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/profile_background_preview"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/backgroundPreviewHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/profile_background_empty"
                    android:textColor="@color/brand_text_muted"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/backgroundBrightnessLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="@color/brand_text"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/backgroundBrightnessSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="145"
                    android:progress="65" />

                <TextView
                    android:id="@+id/backgroundBlurLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/brand_text"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/backgroundBlurSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="25"
                    android:progress="0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chooseBackgroundButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/profile_background_choose" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/applyBackgroundButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/profile_background_apply" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/removeBackgroundButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/profile_background_remove" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
