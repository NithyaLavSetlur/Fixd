<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_card"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="18dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_personal_title"
            android:textColor="@color/brand_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/name_label">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/brand_text"
                android:textColorHint="@color/brand_text_muted" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveNameButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_save_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_email_label"
            android:textColor="@color/brand_text_muted"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/emailSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/brand_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/verificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/brand_text_muted"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendVerificationButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/profile_send_verification"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/profile_focus_title"
            android:textColor="@color/brand_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/focusBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_focus_body"
            android:textColor="@color/brand_text_muted"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/wakeUpCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/problem_wake_up"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/sleepScheduleCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_sleep_schedule"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/timeManagementCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_time_management"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/transportCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_transport"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/socialMediaDistractionCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_social_media_distraction"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/placeholderCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_to_do"
            android:textColor="@color/brand_text" />

        <CheckBox
            android:id="@+id/breatheCheckbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/problem_breathe"
            android:textColor="@color/brand_text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveProfileButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/profile_save_focus" />

        <LinearLayout
            android:id="@+id/credentialsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_credentials_title"
                android:textColor="@color/brand_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/credentialsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/profile_credentials_body"
                android:textColor="@color/brand_text_muted"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/changeEmailButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/profile_change_email" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/changePasswordButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/profile_change_password" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
