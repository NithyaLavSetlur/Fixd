<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    app:statusBarBackground="@android:color/transparent">

    <FrameLayout
        android:id="@+id/dashboardContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/brand_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp">

                <ImageButton
                    android:id="@+id/menuButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_menu_button"
                    android:contentDescription="@string/menu_open"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/brand_text" />

                <TextView
                    android:id="@+id/screenTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/dashboard_title"
                    android:textColor="@color/brand_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/dashboard_body"
                    android:textColor="@color/brand_text_muted"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Fixd.TileCard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="18dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/brand_card"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Fixd.Tile">

                    <FrameLayout
                        android:id="@+id/fragmentContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNavigationView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/brand_card"
                app:itemIconSize="30dp"
                app:itemIconTint="@color/bottom_nav_colors"
                app:itemRippleColor="@color/transparent"
                app:itemTextColor="@color/bottom_nav_colors"
                app:labelVisibilityMode="unlabeled" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/floatingMenuPanel"
            android:layout_width="156dp"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="12dp"
            android:layout_marginTop="84dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:alpha="0"
            app:cardBackgroundColor="@color/brand_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/floatingMenuHome"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/drawer_home" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/floatingMenuProfile"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/drawer_profile" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/floatingMenuSettings"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/drawer_settings" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/floatingMenuPremium"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/drawer_premium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/floatingMenuLogout"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/drawer_logout" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.example.fixd.MistBorderView
            android:id="@+id/dashboardMistBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="16dp"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="264dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/brand_card"
        android:paddingTop="10dp"
        app:headerLayout="@layout/view_drawer_header"
        app:itemBackground="@drawable/bg_drawer_item"
        app:itemIconTint="@color/drawer_item_colors"
        app:itemHorizontalPadding="18dp"
        app:itemIconPadding="14dp"
        app:itemVerticalPadding="4dp"
        app:itemRippleColor="@color/transparent"
        app:itemTextColor="@color/drawer_item_colors"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
