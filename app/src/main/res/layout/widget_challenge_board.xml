<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/challengeWidgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_wake_streak"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/challengeWidgetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/problem_challenges"
                android:textAllCaps="true"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/challengeWidgetLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/challengeWidgetOpenButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_button"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingTop="9dp"
            android:paddingEnd="14dp"
            android:paddingBottom="9dp"
            android:text="@string/challenge_widget_open_board"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/challengeWidgetXp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/challengeWidgetStreak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_widget_panel"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/challengeWidgetMissionsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/challenge_widget_today"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/challengeWidgetMissionOne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:maxLines="1"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/challengeWidgetMissionTwo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/challengeWidgetMissionThree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
