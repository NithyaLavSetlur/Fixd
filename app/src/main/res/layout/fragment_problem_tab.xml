<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tab_card">

    <FrameLayout
        android:id="@+id/wakeUpContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/problemContentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/problemIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_tab_badge"
            android:padding="18dp"
            android:tint="@color/white" />

        <TextView
            android:id="@+id/sectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/brand_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sectionSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAlignment="center"
            android:textColor="@color/brand_text_muted"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
